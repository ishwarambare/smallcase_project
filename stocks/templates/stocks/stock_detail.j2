{% extends 'stocks/base.j2' %}
{% block title %}{{ fundamentals.name }} ({{ symbol }}) — Stock Analysis{% endblock %}

{% block header %}
    {{ super() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
{% endblock %}

{% block css %}
<link rel="stylesheet" href="{{ static('css/pages/stock_detail.css') }}">
{% endblock %}

{% block content %}
<div class="stock-detail-container">

    {# ---- Back Link ---- #}
    <a href="{{ url('home') }}" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
        Back to Dashboard
    </a>

    {# ---- Hero ---- #}
    <div class="stock-hero">
        <div class="stock-hero-left">
            <div class="stock-ticker">
                <span class="live-dot"></span>
                {{ symbol }}
            </div>
            <div class="stock-company-name">{{ fundamentals.name or symbol }}</div>
            {% if fundamentals.sector and fundamentals.sector != 'N/A' %}
            <span class="stock-sector-badge">{{ fundamentals.sector }}{% if fundamentals.industry and fundamentals.industry != 'N/A' %} · {{ fundamentals.industry }}{% endif %}</span>
            {% endif %}
        </div>

        <div class="stock-hero-right">
            <div class="stock-current-price">
                {% if fundamentals.current_price %}
                    ₹{{ "%.2f"|format(fundamentals.current_price) }}
                {% else %}
                    <span style="color:var(--text-secondary);font-size:1.2rem;">Price unavailable</span>
                {% endif %}
            </div>
            {% if day_change is not none %}
            <div class="day-change {% if day_change >= 0 %}positive{% else %}negative{% endif %}">
                {% if day_change >= 0 %}▲{% else %}▼{% endif %}
                ₹{{ "%.2f"|format(day_change|abs) }} ({{ "%.2f"|format(day_change_pct|abs) }}%)
            </div>
            {% endif %}
        </div>

        {# ---- Recommendation + Score Gauge ---- #}
        <div style="width:100%">
            <div class="recommendation-hero">
                <div class="verdict-badge {{ recommendation.verdict_color }}">
                    {{ recommendation.verdict_emoji }} {{ recommendation.verdict }}
                </div>

                {# SVG Circular Gauge #}
                {% set score = recommendation.score %}
                {% set max_score = recommendation.max_score %}
                {% set score_pct = ((score + max_score) / (max_score * 2) * 100) %}
                {% if score >= 7 %}{% set gauge_color = '#16a34a' %}
                {% elif score >= 3 %}{% set gauge_color = '#22c55e' %}
                {% elif score >= -2 %}{% set gauge_color = '#eab308' %}
                {% elif score >= -5 %}{% set gauge_color = '#f97316' %}
                {% else %}{% set gauge_color = '#ef4444' %}{% endif %}

                <div class="score-gauge-wrap">
                    <svg class="score-gauge-svg" viewBox="0 0 60 60" id="scoreGaugeSvg">
                        <circle class="score-gauge-track" cx="30" cy="30" r="24" />
                        <circle class="score-gauge-fill" id="scoreGaugeFill"
                                cx="30" cy="30" r="24"
                                stroke="{{ gauge_color }}"
                                data-offset="{{ (1 - score_pct / 100) * 150.8 | round(1) }}" />
                        <text class="score-gauge-label" x="30" y="30" style="fill:{{ gauge_color }}">
                            {{ score }}
                        </text>
                    </svg>
                    <div class="score-gauge-text">
                        <div class="score-gauge-number">{{ score }} <span style="font-size:0.8rem;font-weight:500;color:var(--text-secondary);">/ {{ max_score }}</span></div>
                        <div class="score-gauge-sub">Intelligence Score</div>
                    </div>
                </div>

                <button class="score-breakdown-toggle" onclick="toggleBreakdown()">
                    📊 Score Breakdown ▾
                </button>

                <span class="last-updated-chip">
                    🕒 Live data · cached 15 min
                </span>
            </div>

            {# ---- Score Breakdown Panel ---- #}
            <div class="score-breakdown-panel" id="scoreBreakdownPanel">
                <div class="score-breakdown-grid">

                    {# Helper macro for breakdown items #}
                    {% macro breakdown_item(label, score_val, max_val) %}
                    {% set pct = ((score_val + max_val) / (max_val * 2) * 100) if max_val > 0 else 50 %}
                    {% set cls = 'positive' if score_val > 0 else ('negative' if score_val < 0 else 'neutral') %}
                    <div class="score-breakdown-item">
                        <div class="score-breakdown-label">
                            <span>{{ label }}</span>
                            <span style="color:{% if score_val > 0 %}#16a34a{% elif score_val < 0 %}#dc2626{% else %}#eab308{% endif %}">{{ '+' if score_val > 0 else '' }}{{ score_val }}</span>
                        </div>
                        <div class="score-breakdown-bar">
                            <div class="score-breakdown-fill {{ cls }}" style="width:{{ pct|round(1) }}%"></div>
                        </div>
                    </div>
                    {% endmacro %}

                    {# Compute sub-scores from reasons count #}
                    {% set tech_score = 0 %}
                    {% if indicators.rsi_signal == 'bullish' %}{% set tech_score = tech_score + 1 %}{% elif indicators.rsi_signal == 'bearish' %}{% set tech_score = tech_score - 1 %}{% endif %}
                    {% if indicators.sma50_signal == 'bullish' %}{% set tech_score = tech_score + 1 %}{% elif indicators.sma50_signal == 'bearish' %}{% set tech_score = tech_score - 1 %}{% endif %}
                    {% if indicators.sma200_signal == 'bullish' %}{% set tech_score = tech_score + 1 %}{% elif indicators.sma200_signal == 'bearish' %}{% set tech_score = tech_score - 1 %}{% endif %}
                    {% if indicators.macd_signal == 'bullish' %}{% set tech_score = tech_score + 1 %}{% elif indicators.macd_signal == 'bearish' %}{% set tech_score = tech_score - 1 %}{% endif %}
                    {% if indicators.bb_signal == 'bullish' %}{% set tech_score = tech_score + 1 %}{% elif indicators.bb_signal == 'bearish' %}{% set tech_score = tech_score - 1 %}{% endif %}
                    {% if indicators.volume_signal == 'bullish' %}{% set tech_score = tech_score + 1 %}{% endif %}

                    {{ breakdown_item('📉 Technicals', tech_score, 6) }}
                    {{ breakdown_item('📊 News Sentiment', news.sentiment_score, 1) }}
                    {{ breakdown_item('📦 Ownership', ownership.score, 3) }}
                    {{ breakdown_item('🏛️ Policy', policy.score, 1) }}
                    {{ breakdown_item('🌍 Global', global_data.score, 4) }}
                </div>
            </div>
        </div>
    </div>

    {# ---- Key Fundamentals ---- #}
    <div class="detail-section">
        <div class="section-heading">📊 Key Fundamentals</div>
        <div class="metrics-grid">

            {% macro metric(label, value, fmt='plain', cls='') %}
            <div class="metric-card">
                <div class="metric-label">{{ label }}</div>
                <div class="metric-value {{ cls }}">
                    {% if value is none %}—
                    {% elif fmt == 'price' %}₹{{ "%.2f"|format(value) }}
                    {% elif fmt == 'cr' %}
                        {% if value >= 1e12 %}₹{{ "%.2f"|format(value/1e12) }}L Cr
                        {% elif value >= 1e9 %}₹{{ "%.2f"|format(value/1e9) }} Cr
                        {% elif value >= 1e7 %}₹{{ "%.2f"|format(value/1e7) }} Cr
                        {% else %}₹{{ "%.0f"|format(value) }}
                        {% endif %}
                    {% elif fmt == 'pct' %}{{ "%.2f"|format(value * 100) }}%
                    {% elif fmt == 'vol' %}{{ "{:,}".format(value|int) }}
                    {% elif fmt == 'x' %}{{ "%.2f"|format(value) }}x
                    {% elif fmt == 'dec2' %}{{ "%.2f"|format(value) }}
                    {% else %}{{ value }}
                    {% endif %}
                </div>
            </div>
            {% endmacro %}

            {{ metric("Current Price", fundamentals.current_price, 'price') }}
            {{ metric("Day Open", fundamentals.open, 'price') }}
            {{ metric("Day High", fundamentals.day_high, 'price') }}
            {{ metric("Day Low", fundamentals.day_low, 'price') }}
            {{ metric("Prev. Close", fundamentals.previous_close, 'price') }}
            {{ metric("Market Cap", fundamentals.market_cap, 'cr') }}
            {{ metric("P/E Ratio", fundamentals.pe_ratio, 'dec2') }}
            {{ metric("Forward P/E", fundamentals.forward_pe, 'dec2') }}
            {{ metric("EPS (TTM)", fundamentals.eps, 'price') }}
            {{ metric("Dividend Yield", fundamentals.dividend_yield, 'pct') }}
            {{ metric("Beta", fundamentals.beta, 'dec2') }}
            {{ metric("Book Value", fundamentals.book_value, 'price') }}
            {{ metric("Price/Book", fundamentals.price_to_book, 'x') }}
            {{ metric("Volume", fundamentals.volume, 'vol') }}
            {{ metric("Avg. Volume", fundamentals.avg_volume, 'vol') }}
            {{ metric("52W High", fundamentals.week_52_high, 'price') }}
            {{ metric("52W Low", fundamentals.week_52_low, 'price') }}
        </div>

        {# 52-week range bar #}
        {% if week52_pct is not none %}
        <div style="margin-top:22px;">
            <div style="font-size:0.78rem;font-weight:700;text-transform:uppercase;color:var(--text-secondary);letter-spacing:.06em;margin-bottom:8px;">
                52-Week Range Position
            </div>
            <div style="display:flex;align-items:center;gap:12px;font-size:0.82rem;color:var(--text-secondary);">
                <span>₹{{ "%.0f"|format(fundamentals.week_52_low) }}</span>
                <div class="week52-bar-wrap" style="flex:1;position:relative;">
                    <div class="week52-bar-fill" style="width:100%;"></div>
                    <div class="week52-marker" style="left:{{ week52_pct }}%;"></div>
                </div>
                <span>₹{{ "%.0f"|format(fundamentals.week_52_high) }}</span>
            </div>
            <div style="margin-top:6px;font-size:0.8rem;color:var(--text-secondary);text-align:center;">
                Current price is at <strong>{{ week52_pct }}%</strong> of the 52-week range
            </div>
        </div>
        {% endif %}
    </div>

    {# ---- Ownership & Market Depth ---- #}
    <div class="detail-section">
        <div class="section-heading">📦 Market Depth &amp; Ownership</div>

        <div class="ownership-grid">
            <div class="ownership-card">
                <div class="ownership-label">Bid / Ask Spread</div>
                <div class="ownership-value">
                    {% if ownership.spread %}
                        ₹{{ ownership.spread }} <span style="font-size:0.8rem;color:var(--text-secondary);font-weight:600;">({{ ownership.spread_pct|round(2) }}%)</span>
                    {% else %}—{% endif %}
                </div>
                <div style="font-size:0.75rem;color:var(--text-secondary);margin-top:6px;">
                    Bid: {% if ownership.bid %}₹{{ ownership.bid }}{% else %}—{% endif %} · Ask: {% if ownership.ask %}₹{{ ownership.ask }}{% else %}—{% endif %}
                </div>
            </div>
            <div class="ownership-card">
                <div class="ownership-label">Institutional Holding</div>
                <div class="ownership-value">{% if ownership.inst_holding_pct %}{{ ownership.inst_holding_pct }}%{% else %}—{% endif %}</div>
                {% if ownership.inst_holding_pct %}
                <div class="ownership-bar-wrap">
                    <div class="ownership-bar-fill" style="width:{{ [ownership.inst_holding_pct, 100]|min }}%; background:{% if ownership.inst_holding_pct > 30 %}#16a34a{% else %}#3b82f6{% endif %};"></div>
                </div>
                <div style="font-size:0.72rem;color:var(--text-secondary);margin-top:5px;">
                    {% if ownership.inst_holding_pct > 40 %}💪 Strong institutional interest{% elif ownership.inst_holding_pct > 20 %}Moderate institutional presence{% else %}Low institutional interest{% endif %}
                </div>
                {% endif %}
            </div>
            <div class="ownership-card">
                <div class="ownership-label">Promoter / Insider</div>
                <div class="ownership-value">{% if ownership.insider_holding_pct %}{{ ownership.insider_holding_pct }}%{% else %}—{% endif %}</div>
                {% if ownership.insider_holding_pct %}
                <div class="ownership-bar-wrap">
                    <div class="ownership-bar-fill" style="width:{{ [ownership.insider_holding_pct, 100]|min }}%; background:{% if ownership.insider_holding_pct > 50 %}#16a34a{% else %}#3b82f6{% endif %};"></div>
                </div>
                <div style="font-size:0.72rem;color:var(--text-secondary);margin-top:5px;">
                    {% if ownership.insider_holding_pct > 50 %}🔒 High promoter confidence{% elif ownership.insider_holding_pct > 25 %}Moderate promoter stake{% else %}Low promoter stake{% endif %}
                </div>
                {% endif %}
            </div>
            <div class="ownership-card">
                <div class="ownership-label">Float Shares</div>
                <div class="ownership-value">
                    {% if ownership.float_shares %}
                        {% if ownership.float_shares >= 1e9 %}{{ "%.2f"|format(ownership.float_shares/1e9) }}B
                        {% elif ownership.float_shares >= 1e6 %}{{ "%.2f"|format(ownership.float_shares/1e6) }}M
                        {% else %}{{ "{:,}".format(ownership.float_shares|int) }}{% endif %}
                    {% else %}—{% endif %}
                </div>
                {% if ownership.shares_outstanding and ownership.float_shares %}
                <div style="font-size:0.72rem;color:var(--text-secondary);margin-top:6px;">
                    {{ "%.1f"|format((ownership.float_shares / ownership.shares_outstanding) * 100) }}% of outstanding shares
                </div>
                {% endif %}
                {% if ownership.short_ratio %}
                <div style="font-size:0.72rem;color:var(--text-secondary);margin-top:4px;">
                    Short ratio: <strong>{{ ownership.short_ratio }}</strong>
                </div>
                {% endif %}
            </div>
        </div>

        {# Donut chart if we have both inst + insider data #}
        {% if ownership.inst_holding_pct and ownership.insider_holding_pct %}
        <div class="ownership-donut-wrap" style="margin-top:16px;">
            <div class="ownership-donut-canvas-wrap">
                <canvas id="ownershipDonut" width="100" height="100"></canvas>
            </div>
            <div class="ownership-donut-legend">
                <div class="donut-legend-item">
                    <span class="donut-legend-dot" style="background:#3b82f6;"></span>
                    Institutional <span class="donut-legend-val">{{ ownership.inst_holding_pct }}%</span>
                </div>
                <div class="donut-legend-item">
                    <span class="donut-legend-dot" style="background:#8b5cf6;"></span>
                    Promoter/Insider <span class="donut-legend-val">{{ ownership.insider_holding_pct }}%</span>
                </div>
                <div class="donut-legend-item">
                    <span class="donut-legend-dot" style="background:var(--border-color);"></span>
                    Public Float <span class="donut-legend-val">{{ "%.1f"|format([100 - ownership.inst_holding_pct - ownership.insider_holding_pct, 0]|max) }}%</span>
                </div>
            </div>
        </div>
        {% endif %}

        {# Ownership signals #}
        {% if ownership.signals %}
        <div class="ownership-signals">
            {% for sig_type, sig_text in ownership.signals %}
            <div class="ownership-signal-row {{ sig_type }}">
                <span>{% if sig_type == 'bullish' %}✅{% else %}⚠️{% endif %}</span>
                <span>{{ sig_text }}</span>
            </div>
            {% endfor %}
        </div>
        {% endif %}
    </div>

    {# ---- Technical Indicators ---- #}
    <div class="detail-section">
        <div class="section-heading">📉 Technical Indicators</div>
        {% if indicators.error %}
        <div style="color:var(--text-secondary);font-style:italic;">⚠ {{ indicators.error }}</div>
        {% else %}
        <div class="indicators-grid">

            {# RSI #}
            <div class="indicator-row {{ indicators.rsi_signal }}">
                <div>
                    <div class="indicator-name">RSI (14-day)</div>
                    <div class="indicator-val">{{ indicators.rsi if indicators.rsi else "—" }}
                        {% if indicators.rsi %}&nbsp;·
                            {% if indicators.rsi < 30 %}Oversold{% elif indicators.rsi > 70 %}Overbought{% else %}Neutral zone{% endif %}
                        {% endif %}
                    </div>
                </div>
                <span class="indicator-signal {{ indicators.rsi_signal }}">
                    {% if indicators.rsi_signal == 'bullish' %}Buy Signal{% elif indicators.rsi_signal == 'bearish' %}Sell Signal{% else %}Neutral{% endif %}
                </span>
            </div>

            {# SMA 50 #}
            {% if indicators.sma50 %}
            <div class="indicator-row {{ indicators.sma50_signal }}">
                <div>
                    <div class="indicator-name">50-Day SMA</div>
                    <div class="indicator-val">₹{{ indicators.sma50 }} ·
                        {% if indicators.sma50_signal == 'bullish' %}Price above SMA{% else %}Price below SMA{% endif %}
                    </div>
                </div>
                <span class="indicator-signal {{ indicators.sma50_signal }}">
                    {% if indicators.sma50_signal == 'bullish' %}Bullish{% else %}Bearish{% endif %}
                </span>
            </div>
            {% endif %}

            {# SMA 200 #}
            {% if indicators.sma200 %}
            <div class="indicator-row {{ indicators.sma200_signal }}">
                <div>
                    <div class="indicator-name">200-Day SMA</div>
                    <div class="indicator-val">₹{{ indicators.sma200 }} ·
                        {% if indicators.sma200_signal == 'bullish' %}Price above SMA{% else %}Price below SMA{% endif %}
                    </div>
                </div>
                <span class="indicator-signal {{ indicators.sma200_signal }}">
                    {% if indicators.sma200_signal == 'bullish' %}Bullish{% else %}Bearish{% endif %}
                </span>
            </div>
            {% endif %}

            {# MACD #}
            {% if indicators.macd is not none %}
            <div class="indicator-row {{ indicators.macd_signal }}">
                <div>
                    <div class="indicator-name">MACD (12, 26, 9)</div>
                    <div class="indicator-val">MACD {{ indicators.macd }} · Signal {{ indicators.macd_signal_line }}</div>
                </div>
                <span class="indicator-signal {{ indicators.macd_signal }}">
                    {% if indicators.macd_signal == 'bullish' %}Bullish{% else %}Bearish{% endif %}
                </span>
            </div>
            {% endif %}

            {# Bollinger Bands #}
            {% if indicators.bb_upper %}
            <div class="indicator-row {{ indicators.bb_signal }}">
                <div>
                    <div class="indicator-name">Bollinger Bands</div>
                    <div class="indicator-val">Upper ₹{{ indicators.bb_upper }} · Lower ₹{{ indicators.bb_lower }}</div>
                </div>
                <span class="indicator-signal {{ indicators.bb_signal }}">
                    {% if indicators.bb_signal == 'bullish' %}Near Support{% elif indicators.bb_signal == 'bearish' %}Near Resistance{% else %}Mid Range{% endif %}
                </span>
            </div>
            {% endif %}

            {# Volume #}
            <div class="indicator-row {{ indicators.volume_signal }}">
                <div>
                    <div class="indicator-name">Volume Trend</div>
                    <div class="indicator-val">
                        Today {{ "{:,}".format(indicators.current_volume) if indicators.current_volume else "—" }} ·
                        10D Avg {{ "{:,}".format(indicators.avg_volume_10) if indicators.avg_volume_10 else "—" }}
                    </div>
                </div>
                <span class="indicator-signal {{ indicators.volume_signal }}">
                    {% if indicators.volume_signal == 'bullish' %}High Volume{% else %}Normal{% endif %}
                </span>
            </div>

        </div>
        {% endif %}
    </div>

    {# ---- Govt Policy Alignment ---- #}
    <div class="detail-section">
        <div class="section-heading">🏛️ Government Policy Alignment</div>
        {% if policy.matched_themes %}
        <div style="margin-bottom:14px;font-size:0.875rem;color:var(--text-secondary);">
            This stock's sector and recent news align with <strong>{{ policy.matched_themes|length }}</strong> active Indian government policy theme(s):
        </div>
        <div class="policy-themes-grid">
            {% for theme in policy.matched_themes %}
            {% if theme.match_type == 'sector+news' %}{% set tag_class = 'policy-tag-both' %}{% set badge_text = '✦ Sector + News' %}
            {% elif theme.match_type == 'sector' %}{% set tag_class = 'policy-tag-sector' %}{% set badge_text = '⬡ Sector' %}
            {% else %}{% set tag_class = 'policy-tag-news' %}{% set badge_text = '◉ News' %}{% endif %}
            <div class="policy-theme-tag {{ tag_class }}" title="{{ theme.description }}">
                <span>{{ theme.name }}</span>
                <span class="policy-match-badge">{{ badge_text }}</span>
            </div>
            {% endfor %}
        </div>
        <div class="policy-score-info">
            <span>ℹ️</span>
            <span>
                Policy alignment adds <strong>+1</strong> to the overall score.
                Themes are matched using sector classification and recent news keywords.
                <em>Sector match (blue) · News keyword match (purple) · Both (green)</em>
            </span>
        </div>
        {% else %}
        <div class="policy-no-match">
            <span style="font-size:1.2rem;">ℹ️</span> No strong direct policy tailwinds identified currently.
        </div>
        {% endif %}
    </div>

    {# ---- Global Market Impact ---- #}
    <div class="detail-section">
        <div class="section-heading">🌍 Global Market Impact (5-Day Trend)</div>
        <div class="global-grid">
            {% for sym, data in global_data.indicators.items() %}
            <div class="global-card {{ data.impact }}">
                <span class="global-icon">{{ data.icon }}</span>
                <div class="global-name">{{ data.name }}</div>
                <div class="global-value">{{ data.value }}</div>
                <div class="global-change {{ data.trend }}">
                    {% if data.trend == 'up' %}▲ +{% elif data.trend == 'down' %}▼ {% else %}— {% endif %}
                    {{ data.pct_change }}%
                </div>
                <div class="global-impact-pill {{ data.impact }}">
                    {% if data.impact == 'bullish' %}✅ Positive Impact{% elif data.impact == 'bearish' %}⚠️ Negative Impact{% else %}⚖️ Neutral Impact{% endif %}
                </div>
                <div class="global-desc">{{ data.description }}</div>
                {% if data.signal_text %}
                <div class="global-desc" style="margin-top:4px;font-style:italic;">{{ data.signal_text }}</div>
                {% endif %}
            </div>
            {% endfor %}
        </div>
    </div>

    {# ---- Should I Buy? ---- #}
    <div class="detail-section">
        <div class="section-heading">🤔 Should I Buy? — Full Analysis</div>
        <div class="reasons-grid">
            <div class="reasons-column bullish-col">
                <h4>✅ Bullish Signals ({{ recommendation.bullish_reasons|length }})</h4>
                {% if recommendation.bullish_reasons %}
                    {% for reason in recommendation.bullish_reasons %}
                    <div class="reason-item bullish">
                        <span class="reason-icon">✅</span>
                        <span>{{ reason }}</span>
                    </div>
                    {% endfor %}
                {% else %}
                <div class="no-reasons">No bullish signals found for this stock.</div>
                {% endif %}
            </div>
            <div class="reasons-column bearish-col">
                <h4>❌ Risk Factors ({{ recommendation.bearish_reasons|length }})</h4>
                {% if recommendation.bearish_reasons %}
                    {% for reason in recommendation.bearish_reasons %}
                    <div class="reason-item bearish">
                        <span class="reason-icon">❌</span>
                        <span>{{ reason }}</span>
                    </div>
                    {% endfor %}
                {% else %}
                <div class="no-reasons">No major risk factors detected.</div>
                {% endif %}
            </div>
        </div>
        <div class="analysis-disclaimer">
            ⚠️ <strong>Disclaimer:</strong> This analysis is for educational purposes only and is not financial advice.
            Always do your own research and consult a SEBI-registered financial advisor before investing.
        </div>
    </div>

    {# ---- Price Chart ---- #}
    <div class="detail-section">
        <div class="section-heading">📈 Price History</div>
        <div class="period-btns">
            {% for p, label in [('1d','1D'),('7d','1W'),('1m','1M'),('3m','3M'),('6m','6M'),('1y','1Y')] %}
            <button class="period-btn-detail {% if p == '1m' %}active{% endif %}" data-period="{{ p }}">{{ label }}</button>
            {% endfor %}
        </div>
        <div id="chart-loading" style="text-align:center;padding:40px;color:var(--text-secondary);display:none;">Loading chart…</div>
        <div id="chart-error" style="text-align:center;padding:40px;color:#dc2626;display:none;"></div>
        <div style="position:relative;height:360px;">
            <canvas id="priceChart"></canvas>
        </div>
    </div>

    {# ---- News Sentiment ---- #}
    <div class="detail-section">
        <div class="section-heading">📰 Latest News &amp; Sentiment</div>

        <div class="news-sentiment-bar">
            <div class="sentiment-badge {{ news.sentiment }}">
                {% if news.sentiment == 'positive' %}📈{% elif news.sentiment == 'negative' %}📉{% else %}⚖️{% endif %}
                Overall: {{ news.sentiment|title }}
            </div>
            <div class="news-count-pills">
                <span style="color:#16a34a;font-weight:700;">{{ news.positive_count }} Positive</span> •
                <span style="color:#dc2626;font-weight:700;">{{ news.negative_count }} Negative</span> •
                <span>{{ news.neutral_count }} Neutral</span>
            </div>
        </div>

        {# Filter buttons #}
        {% if news.articles %}
        <div class="news-filter-row">
            <button class="news-filter-btn active" data-filter="all" onclick="filterNews(this,'all')">All ({{ news.articles|length }})</button>
            <button class="news-filter-btn f-positive" data-filter="positive" onclick="filterNews(this,'positive')">✅ Positive ({{ news.positive_count }})</button>
            <button class="news-filter-btn f-negative" data-filter="negative" onclick="filterNews(this,'negative')">❌ Negative ({{ news.negative_count }})</button>
            <button class="news-filter-btn f-neutral" data-filter="neutral" onclick="filterNews(this,'neutral')">⚖️ Neutral ({{ news.neutral_count }})</button>
        </div>

        <div class="news-grid" id="newsGrid">
            {% for article in news.articles %}
            <a href="{{ article.url }}" target="_blank" class="news-card" data-sentiment="{{ article.sentiment }}" style="text-decoration:none;color:inherit;">
                <div class="news-card-sentiment-bar {{ article.sentiment }}"></div>
                {% if article.thumbnail %}
                <img src="{{ article.thumbnail }}" alt="News thumbnail" class="news-thumb">
                {% else %}
                <div class="news-thumb" style="display:flex;align-items:center;justify-content:center;color:var(--text-secondary);font-size:2.5rem;background:var(--bg-body);">📰</div>
                {% endif %}
                <div class="news-card-body">
                    <div class="news-card-meta">
                        <span class="news-provider">{{ article.provider }}</span>
                        <span class="news-date">{{ article.date }}</span>
                    </div>
                    <div class="news-title">{{ article.title }}</div>
                    <div class="news-summary">{{ article.summary }}</div>
                    <div class="news-footer">
                        <span class="news-pill {{ article.sentiment }}">{{ article.sentiment|title }}</span>
                        <span class="news-read-link">Read full story →</span>
                    </div>
                </div>
            </a>
            {% endfor %}
        </div>
        {% else %}
        <div style="color:var(--text-secondary);font-style:italic;">No recent news found for this stock.</div>
        {% endif %}
    </div>

    {# ---- About ---- #}
    {% if fundamentals.description %}
    <div class="detail-section">
        <div class="section-heading">🏢 About {{ fundamentals.name }}</div>
        <div class="stock-description" id="stockDescription">{{ fundamentals.description }}</div>
        <button class="read-more-btn" id="readMoreBtn" onclick="toggleDescription()">Read more ▼</button>
    </div>
    {% endif %}

    {# ======================================================= #}
    {# ---- AI Research Summary (async LLM) ---- #}
    {# ======================================================= #}
    <div class="detail-section ai-summary-section" id="aiSummarySection">
        <div class="section-heading">
            🤖 AI Research Summary
            <span class="ai-badge">Powered by AI</span>
        </div>
        <div id="aiSummaryContent">
            <div class="ai-loading" id="aiSummaryLoading">
                <div class="ai-spinner"></div>
                <span>Generating AI analysis…</span>
            </div>
            <div id="aiSummaryResult" style="display:none;">
                <div class="ai-summary-grid">
                    <div class="ai-summary-card overview-card">
                        <div class="ai-card-icon">🏢</div>
                        <div class="ai-card-title">Business Overview</div>
                        <div class="ai-card-body" id="aiOverview"></div>
                    </div>
                    <div class="ai-summary-card bullish-card">
                        <div class="ai-card-icon">✅</div>
                        <div class="ai-card-title">Bullish Signals</div>
                        <div class="ai-card-body" id="aiBullish"></div>
                    </div>
                    <div class="ai-summary-card risk-card">
                        <div class="ai-card-icon">⚠️</div>
                        <div class="ai-card-title">Key Risks</div>
                        <div class="ai-card-body" id="aiRisks"></div>
                    </div>
                </div>
                <div class="ai-summary-footer" id="aiSummaryFooter"></div>
            </div>
            <div id="aiSummaryError" style="display:none;" class="ai-error"></div>
        </div>
    </div>

    {# ======================================================= #}
    {# ---- Quant Intelligence Metrics ---- #}
    {# ======================================================= #}
    <div class="detail-section quant-section">
        <div class="section-heading">
            📐 Quant Intelligence Metrics
            <span class="quant-badge">Advanced</span>
        </div>
        <div class="quant-grid">

            {# Sharpe Ratio #}
            <div class="quant-card {{ quant.sharpe_signal }}">
                <div class="quant-icon">📊</div>
                <div class="quant-label">Sharpe Ratio</div>
                <div class="quant-value">
                    {% if quant.sharpe_ratio is not none %}
                        {{ "%.2f"|format(quant.sharpe_ratio) }}
                    {% else %}—{% endif %}
                </div>
                <div class="quant-signal-pill {{ quant.sharpe_signal }}">
                    {% if quant.sharpe_ratio is not none %}
                        {% if quant.sharpe_ratio > 1.0 %}Excellent Risk-Return{% elif quant.sharpe_ratio > 0 %}Acceptable{% else %}Poor Risk-Return{% endif %}
                    {% else %}Data Unavailable{% endif %}
                </div>
                <div class="quant-tooltip">Return earned per unit of total risk (>1.0 = good). Uses 6.5% RBI rate as risk-free proxy.</div>
            </div>

            {# Sortino Ratio #}
            <div class="quant-card {{ quant.sortino_signal }}">
                <div class="quant-icon">📉</div>
                <div class="quant-label">Sortino Ratio</div>
                <div class="quant-value">
                    {% if quant.sortino_ratio is not none %}
                        {{ "%.2f"|format(quant.sortino_ratio) }}
                    {% else %}—{% endif %}
                </div>
                <div class="quant-signal-pill {{ quant.sortino_signal }}">
                    {% if quant.sortino_ratio is not none %}
                        {% if quant.sortino_ratio > 1.5 %}Strong Downside Protection{% elif quant.sortino_ratio > 0 %}Moderate{% else %}High Downside Risk{% endif %}
                    {% else %}Data Unavailable{% endif %}
                </div>
                <div class="quant-tooltip">Like Sharpe, but only penalises downside volatility (>1.5 = strong).</div>
            </div>

            {# ADV-30 #}
            <div class="quant-card {{ quant.adv_signal }}">
                <div class="quant-icon">💧</div>
                <div class="quant-label">ADV-30 (Liquidity)</div>
                <div class="quant-value">
                    {% if quant.adv_30 %}
                        {% if quant.adv_30 >= 1000000 %}{{ "%.1f"|format(quant.adv_30 / 1000000) }}M{% else %}{{ "{:,}".format(quant.adv_30) }}{% endif %}
                    {% else %}—{% endif %}
                </div>
                <div class="quant-signal-pill {{ quant.adv_signal }}">
                    {% if quant.adv_30 %}
                        {% if quant.adv_30 >= 500000 %}High Liquidity{% elif quant.adv_30 >= 100000 %}Moderate{% else %}Low Liquidity{% endif %}
                    {% else %}Data Unavailable{% endif %}
                </div>
                <div class="quant-tooltip">30-day Average Daily Volume. Low ADV (&lt;100K) means large trades can move the price significantly.</div>
            </div>

            {# Put/Call Ratio #}
            <div class="quant-card {{ quant.pcr_signal }}">
                <div class="quant-icon">⚖️</div>
                <div class="quant-label">Put/Call Ratio</div>
                <div class="quant-value">
                    {% if quant.put_call_ratio is not none %}{{ quant.put_call_ratio }}{% else %}—{% endif %}
                </div>
                <div class="quant-signal-pill {{ quant.pcr_signal }}">
                    {% if quant.put_call_ratio is not none %}
                        {% if quant.put_call_ratio > 1.2 %}Bearish Bets Heavy{% elif quant.put_call_ratio < 0.7 %}Bullish Sentiment{% else %}Balanced Market{% endif %}
                    {% else %}No Options Data{% endif %}
                </div>
                <div class="quant-tooltip">PCR &gt;1.2 = more puts = bearish. PCR &lt;0.7 = more calls = bullish.</div>
            </div>

            {# Implied Volatility #}
            <div class="quant-card {{ quant.iv_signal }}">
                <div class="quant-icon">🌊</div>
                <div class="quant-label">Implied Volatility</div>
                <div class="quant-value">
                    {% if quant.implied_volatility is not none %}{{ quant.implied_volatility }}%{% else %}—{% endif %}
                </div>
                <div class="quant-signal-pill {{ quant.iv_signal }}">
                    {% if quant.implied_volatility is not none %}
                        {% if quant.implied_volatility > 40 %}High Uncertainty{% elif quant.implied_volatility < 20 %}Low Volatility Expected{% else %}Moderate Swing Expected{% endif %}
                    {% else %}No Options Data{% endif %}
                </div>
                <div class="quant-tooltip">Market's expected future volatility. High IV before earnings = expect big moves.</div>
            </div>

        </div>
        {% if quant.error %}
        <div style="margin-top:12px;font-size:0.78rem;color:var(--text-secondary);font-style:italic;">
            ⚠ Some quant metrics unavailable: {{ quant.error }}
        </div>
        {% endif %}
    </div>

    {# ======================================================= #}
    {# ---- Financial Document RAG — Chat with Documents ---- #}
    {# ======================================================= #}
    <div class="detail-section rag-section" id="ragSection">
        <div class="section-heading">
            📄 Chat with Documents
            <span class="rag-badge">RAG Pipeline</span>
        </div>
        <div class="rag-description">
            Ask questions about {{ fundamentals.name }}'s annual reports, earnings call transcripts, and research reports.
        </div>

        {# Document list area #}
        <div class="rag-docs-panel" id="ragDocsPanel">
            <div class="rag-docs-loading">Loading documents…</div>
        </div>

        {# Upload form (admin only — shown via JS if user is staff) #}
        {% if request.user.is_authenticated and (request.user.is_staff or request.user.is_superuser) %}
        <details class="rag-upload-panel" id="ragUploadPanel">
            <summary class="rag-upload-toggle">📤 Upload Document (Admin)</summary>
            <div class="rag-upload-form">
                <div class="rag-form-row">
                    <input type="text" id="ragDocTitle" placeholder="Document title (e.g. Q2 FY2025 Earnings Call)" class="rag-input">
                    <select id="ragDocType" class="rag-select">
                        <option value="annual_report">Annual Report</option>
                        <option value="earnings_call" selected>Earnings Call</option>
                        <option value="investor_presentation">Investor Presentation</option>
                        <option value="research_report">Research Report</option>
                        <option value="other">Other</option>
                    </select>
                    <input type="text" id="ragFiscalYear" placeholder="FY2025 / Q2-2025" class="rag-input" style="max-width:140px;">
                </div>
                <div class="rag-form-row" style="margin-top:10px;">
                    <input type="file" id="ragFileInput" accept=".pdf" class="rag-file-input">
                    <button class="rag-upload-btn" id="ragUploadBtn" onclick="uploadRagDocument()">
                        📤 Upload & Index PDF
                    </button>
                </div>
                <div id="ragUploadStatus" style="margin-top:8px;font-size:0.82rem;"></div>
            </div>
        </details>
        {% endif %}

        {# Chat Interface #}
        <div class="rag-chat-container" id="ragChatContainer">
            <div class="rag-chat-messages" id="ragMessages">
                <div class="rag-welcome-message">
                    <div class="rag-welcome-icon">💬</div>
                    <div>
                        <div style="font-weight:700;margin-bottom:4px;">Chat with {{ symbol }} Documents</div>
                        <div style="font-size:0.82rem;color:var(--text-secondary);">Ask anything about earnings calls, annual reports, or investor presentations.</div>
                        <div class="rag-example-questions" style="margin-top:10px;display:flex;flex-wrap:wrap;gap:6px;">
                            <button class="rag-example-btn" onclick="askRagExample(this)">What are the key revenue drivers?</button>
                            <button class="rag-example-btn" onclick="askRagExample(this)">What did management say about expansion plans?</button>
                            <button class="rag-example-btn" onclick="askRagExample(this)">What are the main risks highlighted?</button>
                            <button class="rag-example-btn" onclick="askRagExample(this)">What is the dividend policy?</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="rag-chat-input-row">
                <input type="text" id="ragQuestion" class="rag-question-input"
                       placeholder="Ask a question about the company's documents…"
                       onkeydown="if(event.key==='Enter') sendRagQuery()">
                <select id="ragFilterType" class="rag-filter-select">
                    <option value="">All Documents</option>
                    <option value="annual_report">Annual Report</option>
                    <option value="earnings_call">Earnings Call</option>
                    <option value="investor_presentation">Investor Pres.</option>
                    <option value="research_report">Research Report</option>
                </select>
                <button class="rag-send-btn" id="ragSendBtn" onclick="sendRagQuery()">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                </button>
            </div>
        </div>
    </div>

</div>
{% endblock %}

{% block javascript %}
<script>
const SYMBOL = "{{ symbol }}";

// ============================================================
// Score Gauge — SVG arc animation
// ============================================================
(function () {
    const fill = document.getElementById('scoreGaugeFill');
    if (!fill) return;
    const targetOffset = parseFloat(fill.dataset.offset || 150.8);
    // Circumference of r=24 circle = 2π×24 ≈ 150.8
    fill.style.strokeDasharray = '150.8';
    fill.style.strokeDashoffset = '150.8'; // start hidden
    requestAnimationFrame(() => {
        fill.style.transition = 'stroke-dashoffset 1.4s cubic-bezier(.4,0,.2,1)';
        fill.style.strokeDashoffset = Math.max(0, Math.min(150.8, targetOffset)).toString();
    });
})();

// ============================================================
// Score Breakdown Toggle
// ============================================================
function toggleBreakdown() {
    const panel = document.getElementById('scoreBreakdownPanel');
    const btn = document.querySelector('.score-breakdown-toggle');
    if (panel.classList.contains('open')) {
        panel.classList.remove('open');
        btn.textContent = '📊 Score Breakdown ▾';
    } else {
        panel.classList.add('open');
        btn.textContent = '📊 Score Breakdown ▴';
    }
}

// ============================================================
// News Filter
// ============================================================
function filterNews(btn, filter) {
    // Update active button
    document.querySelectorAll('.news-filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    // Show/hide cards
    const cards = document.querySelectorAll('#newsGrid .news-card');
    let visibleCount = 0;
    cards.forEach(card => {
        const match = (filter === 'all') || (card.dataset.sentiment === filter);
        card.style.display = match ? '' : 'none';
        if (match) visibleCount++;
    });

    // Update grid empty state
    let emptyMsg = document.getElementById('newsEmptyMsg');
    if (visibleCount === 0) {
        if (!emptyMsg) {
            emptyMsg = document.createElement('div');
            emptyMsg.id = 'newsEmptyMsg';
            emptyMsg.style.cssText = 'color:var(--text-secondary);font-style:italic;grid-column:1/-1;padding:16px 0;';
            emptyMsg.textContent = 'No ' + filter + ' articles found.';
            document.getElementById('newsGrid').appendChild(emptyMsg);
        }
        emptyMsg.style.display = '';
    } else if (emptyMsg) {
        emptyMsg.style.display = 'none';
    }
}

// ============================================================
// Ownership Donut Chart
// ============================================================
(function () {
    const canvas = document.getElementById('ownershipDonut');
    if (!canvas) return;
    const inst    = {{ ownership.inst_holding_pct or 0 }};
    const insider = {{ ownership.insider_holding_pct or 0 }};
    const pub     = Math.max(0, 100 - inst - insider);

    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';

    new Chart(canvas, {
        type: 'doughnut',
        data: {
            labels: ['Institutional', 'Promoter/Insider', 'Public'],
            datasets: [{
                data: [inst, insider, pub],
                backgroundColor: ['#3b82f6', '#8b5cf6', isDark ? '#334155' : '#e2e8f0'],
                borderWidth: 2,
                borderColor: isDark ? '#1e293b' : '#ffffff',
                hoverOffset: 6,
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            cutout: '65%',
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: {
                        label: ctx => ` ${ctx.label}: ${ctx.raw.toFixed(1)}%`
                    }
                }
            },
            animation: { animateRotate: true, duration: 1000 }
        }
    });
})();

// ============================================================
// Price Chart
// ============================================================
let priceChart = null;

async function loadChart(period) {
    const canvas  = document.getElementById('priceChart');
    const loading = document.getElementById('chart-loading');
    const errDiv  = document.getElementById('chart-error');

    loading.style.display = 'block';
    errDiv.style.display  = 'none';
    canvas.style.display  = 'none';

    try {
        const resp = await fetch(`/en/api/stock-history/?symbol=${encodeURIComponent(SYMBOL)}&period=${period}`);
        const data = await resp.json();

        if (!data.success || !data.dates || data.dates.length === 0) {
            errDiv.textContent = 'No chart data available for this period.';
            errDiv.style.display = 'block';
            loading.style.display = 'none';
            return;
        }

        loading.style.display = 'none';
        canvas.style.display  = 'block';

        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        const lineColor = '#3b82f6';

        if (priceChart) priceChart.destroy();
        priceChart = new Chart(canvas, {
            type: 'line',
            data: {
                labels: data.dates,
                datasets: [{
                    label: SYMBOL,
                    data: data.prices,
                    borderColor: lineColor,
                    backgroundColor: lineColor + '18',
                    borderWidth: 2,
                    pointRadius: 0,
                    pointHoverRadius: 5,
                    fill: true,
                    tension: 0.3,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: ctx => `₹${ctx.parsed.y.toFixed(2)}`
                        }
                    }
                },
                scales: {
                    x: {
                        ticks: { maxTicksLimit: 8, color: isDark ? '#94a3b8' : '#64748b' },
                        grid: { color: isDark ? '#1e293b' : '#f1f5f9' }
                    },
                    y: {
                        ticks: {
                            color: isDark ? '#94a3b8' : '#64748b',
                            callback: v => '₹' + v.toFixed(0)
                        },
                        grid: { color: isDark ? '#1e293b' : '#f1f5f9' }
                    }
                }
            }
        });

    } catch(e) {
        errDiv.textContent = 'Failed to load chart data.';
        errDiv.style.display = 'block';
        loading.style.display = 'none';
        console.error(e);
    }
}

document.querySelectorAll('.period-btn-detail').forEach(btn => {
    btn.addEventListener('click', () => {
        document.querySelectorAll('.period-btn-detail').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        loadChart(btn.dataset.period);
    });
});

loadChart('1m');

// ============================================================
// Description Toggle
// ============================================================
function toggleDescription() {
    const desc = document.getElementById('stockDescription');
    const btn  = document.getElementById('readMoreBtn');
    if (desc.classList.contains('expanded')) {
        desc.classList.remove('expanded');
        btn.textContent = 'Read more ▼';
    } else {
        desc.classList.add('expanded');
        btn.textContent = 'Read less ▲';
    }
}

// ============================================================
// AI Research Summary — Async Load
// ============================================================
(async function loadAISummary() {
    const loading = document.getElementById('aiSummaryLoading');
    const result  = document.getElementById('aiSummaryResult');
    const errDiv  = document.getElementById('aiSummaryError');
    const footer  = document.getElementById('aiSummaryFooter');

    try {
        const resp = await fetch(`/en/api/ai/stock-summary/${encodeURIComponent(SYMBOL)}/`);
        const data = await resp.json();

        if (!data.success || (!data.overview && !data.bullish_summary && !data.risk_summary)) {
            errDiv.textContent = '⚠ AI analysis unavailable — check that your GROQ_API_KEY or GEMINI_API_KEY is configured.';
            errDiv.style.display = 'block';
            loading.style.display = 'none';
            return;
        }

        document.getElementById('aiOverview').textContent = data.overview || '—';
        document.getElementById('aiBullish').innerHTML   = (data.bullish_summary || '').replace(/✅/g, '<span class="ai-bullet">✅</span>').replace(/\n/g, '<br>');
        document.getElementById('aiRisks').innerHTML     = (data.risk_summary   || '').replace(/⚠️/g, '<span class="ai-bullet">⚠️</span>').replace(/\n/g, '<br>');
        footer.innerHTML = data.cached
            ? '🕒 Cached result · refreshes every 6 hours'
            : '✨ Live AI analysis · ' + new Date().toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit'});

        loading.style.display = 'none';
        result.style.display  = 'block';
    } catch(e) {
        errDiv.textContent = '⚠ Could not load AI summary.';
        errDiv.style.display = 'block';
        loading.style.display = 'none';
        console.error('[AI Summary]', e);
    }
})();

// ============================================================
// RAG — Load Document List
// ============================================================
(async function loadRagDocuments() {
    const panel = document.getElementById('ragDocsPanel');
    try {
        const resp = await fetch(`/en/api/ai/rag/documents/${encodeURIComponent(SYMBOL)}/`);
        const data = await resp.json();
        if (data.success && data.documents && data.documents.length > 0) {
            panel.innerHTML = `
                <div class="rag-docs-header">📚 ${data.documents.length} Indexed Document(s)</div>
                <div class="rag-docs-list">
                    ${data.documents.map(d => `
                        <div class="rag-doc-item ${d.is_indexed ? 'indexed' : 'pending'}">
                            <span class="rag-doc-type-badge">${d.document_type_display}</span>
                            <span class="rag-doc-title">${d.title}</span>
                            ${d.fiscal_year ? `<span class="rag-doc-fy">${d.fiscal_year}</span>` : ''}
                            <span class="rag-doc-meta">${d.chunk_count} chunks · ${d.uploaded_at}</span>
                        </div>
                    `).join('')}
                </div>`;
        } else {
            panel.innerHTML = `<div class="rag-no-docs">📭 No documents uploaded yet. ${document.getElementById('ragUploadPanel') ? 'Use the Upload section above to add documents.' : 'Ask your admin to upload documents for this stock.'}</div>`;
        }
    } catch(e) {
        panel.innerHTML = '<div class="rag-no-docs">Could not load document list.</div>';
    }
})();

// ============================================================
// RAG — Send Query
// ============================================================
async function sendRagQuery() {
    const input   = document.getElementById('ragQuestion');
    const btn     = document.getElementById('ragSendBtn');
    const msgs    = document.getElementById('ragMessages');
    const filter  = document.getElementById('ragFilterType').value;
    const question = input.value.trim();

    if (!question) return;

    // Add user message bubble
    const userBubble = document.createElement('div');
    userBubble.className = 'rag-msg user-msg';
    userBubble.textContent = question;
    msgs.appendChild(userBubble);

    // Add loading bubble
    const loadBubble = document.createElement('div');
    loadBubble.className = 'rag-msg ai-msg rag-thinking';
    loadBubble.innerHTML = '<div class="rag-dots"><span></span><span></span><span></span></div>';
    msgs.appendChild(loadBubble);
    msgs.scrollTop = msgs.scrollHeight;

    input.value = '';
    btn.disabled = true;

    try {
        const resp = await fetch(`/en/api/ai/rag/query/${encodeURIComponent(SYMBOL)}/`, {
            method: 'POST',
            headers: {'Content-Type': 'application/json', 'X-CSRFToken': getCsrfToken()},
            body: JSON.stringify({question, doc_type: filter || null}),
        });
        const data = await resp.json();
        loadBubble.remove();

        const aiBubble = document.createElement('div');
        aiBubble.className = 'rag-msg ai-msg';

        if (data.success) {
            let html = `<div class="rag-answer">${data.answer.replace(/\n/g, '<br>')}</div>`;
            if (data.sources && data.sources.length) {
                html += `<div class="rag-sources">📎 Sources: ${data.sources.map(s => `<em>${s.title}</em>`).join(', ')}</div>`;
            }
            aiBubble.innerHTML = html;
        } else {
            aiBubble.innerHTML = `<span style="color:#ef4444;">⚠ ${data.error}</span>`;
        }
        msgs.appendChild(aiBubble);
        msgs.scrollTop = msgs.scrollHeight;
    } catch(e) {
        loadBubble.remove();
        const errBubble = document.createElement('div');
        errBubble.className = 'rag-msg ai-msg';
        errBubble.innerHTML = '<span style="color:#ef4444;">⚠ Network error. Please try again.</span>';
        msgs.appendChild(errBubble);
    } finally {
        btn.disabled = false;
        msgs.scrollTop = msgs.scrollHeight;
    }
}

function askRagExample(btn) {
    const input = document.getElementById('ragQuestion');
    input.value = btn.textContent;
    sendRagQuery();
}

// ============================================================
// RAG — Upload Document (Admin)
// ============================================================
async function uploadRagDocument() {
    const fileInput = document.getElementById('ragFileInput');
    const title     = document.getElementById('ragDocTitle').value.trim();
    const docType   = document.getElementById('ragDocType').value;
    const fy        = document.getElementById('ragFiscalYear').value.trim();
    const statusDiv = document.getElementById('ragUploadStatus');
    const btn       = document.getElementById('ragUploadBtn');

    if (!fileInput.files[0]) {
        statusDiv.innerHTML = '<span style="color:#f97316;">Please select a PDF file.</span>';
        return;
    }

    const formData = new FormData();
    formData.append('file', fileInput.files[0]);
    formData.append('title', title || fileInput.files[0].name.replace('.pdf',''));
    formData.append('document_type', docType);
    formData.append('fiscal_year', fy);
    formData.append('csrfmiddlewaretoken', getCsrfToken());

    btn.disabled = true;
    statusDiv.innerHTML = '<span style="color:var(--text-secondary);">⏳ Uploading and indexing PDF…</span>';

    try {
        const resp = await fetch(`/en/api/ai/rag/upload/${encodeURIComponent(SYMBOL)}/`, {
            method: 'POST',
            body: formData,
        });
        const data = await resp.json();
        if (data.success) {
            statusDiv.innerHTML = `<span style="color:#16a34a;">✅ ${data.message} Reload to see in document list.</span>`;
            // Refresh docs panel
            setTimeout(() => location.reload(), 2000);
        } else {
            statusDiv.innerHTML = `<span style="color:#ef4444;">❌ ${data.error}</span>`;
        }
    } catch(e) {
        statusDiv.innerHTML = '<span style="color:#ef4444;">❌ Upload failed. Check network.</span>';
    } finally {
        btn.disabled = false;
    }
}

function getCsrfToken() {
    const cookie = document.cookie.split(';').find(c => c.trim().startsWith('csrftoken='));
    return cookie ? cookie.trim().split('=')[1] : '';
}
</script>
